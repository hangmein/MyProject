generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Chapters {
  Id            Int             @id(map: "PK__Chapters__3214EC07C5083FD4") @default(autoincrement())
  ComicId       Int
  ChapterNumber Float
  Title         String?         @db.NVarChar(255)
  Status        String?         @default("PENDING", map: "DF__Chapters__Status__3C69FB99") @db.VarChar(50)
  SourceUrl     String?         @db.VarChar(500)
  PublishedAt   DateTime?       @default(now(), map: "DF__Chapters__Publis__3E52440B") @db.DateTime
  CreatedAt     DateTime?       @default(now(), map: "DF__Chapters__Create__3F466844") @db.DateTime
  UpdatedAt     DateTime?       @default(now(), map: "DF__Chapters__Update__44FF419A") @db.DateTime
  
  // Relations
  ChapterImages ChapterImages[]
  Pages         Pages[]
  Reports       Reports[]       // <--- THÊM DÒNG NÀY (Để dễ truy vấn ngược)
  
  Comics        Comics          @relation(fields: [ComicId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_Chapters_Comics")

  @@index([ComicId], map: "IX_Chapters_ComicId")
}

model Comics {
  Id          Int       @id(map: "PK__Comics__3214EC072837C6C5") @default(autoincrement())
  Title       String    @db.NVarChar(255)
  Slug        String    @unique(map: "UQ__Comics__BC7B5FB6CD2AD60E") @db.VarChar(255)
  Author      String?   @db.NVarChar(255)
  Description String?   @db.NVarChar(Max)
  CoverImage  String?   @db.VarChar(500)
  BannerImage String?   @db.NVarChar(Max)
  IsFeatured  Boolean?  @default(false, map: "DF__Comics__IsFeatur__440B1D61")
  Category    String?   @db.NVarChar(50)
  CreatedAt   DateTime? @default(now(), map: "DF__Comics__CreatedA__38996AB5") @db.DateTime
  UpdatedAt   DateTime? @default(now(), map: "DF__Comics__UpdatedA__398D8EEE") @db.DateTime
  
  // Relations
  Chapters    Chapters[]
  Reports     Reports[] // <--- THÊM DÒNG NÀY (Để dễ truy vấn ngược)

  @@index([Slug], map: "IX_Comics_Slug")
}

model Pages {
  Id            Int      @id(map: "PK__Pages__3214EC07D6A273C4") @default(autoincrement())
  ChapterId     Int
  PageNumber    Int
  RawImageUrl   String?  @db.VarChar(500)
  FinalImageUrl String?  @db.VarChar(500)
  TextData      String?  @db.NVarChar(Max)
  Chapters      Chapters @relation(fields: [ChapterId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_Pages_Chapters")

  @@index([ChapterId], map: "IX_Pages_ChapterId")
}

model ChapterImages {
  Id         Int      @id(map: "PK__ChapterI__3214EC0796E545FF") @default(autoincrement())
  ChapterId  Int
  ImageUrl   String   @db.NVarChar(Max)
  PageNumber Int
  Chapters   Chapters @relation(fields: [ChapterId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK__ChapterIm__Chapt__47DBAE45")
}

model SystemLogs {
  Id          Int      @id @default(autoincrement())
  Action      String   @db.VarChar(50)
  TargetType  String   @db.VarChar(50)
  TargetId    Int?
  Description String   @db.NVarChar(Max)
  Level       String   @default("INFO") @db.VarChar(20)
  CreatedAt   DateTime @default(now())
}

model Users {
  Id        Int      @id @default(autoincrement())
  Username  String   @unique @db.VarChar(50)
  Password  String   @db.VarChar(255)
  FullName  String?  @db.NVarChar(100)
  CreatedAt DateTime @default(now())
}

model Reports {
  Id         Int       @id @default(autoincrement())
  Content    String    @db.NVarChar(Max)
  Status     String    @default("PENDING") @db.VarChar(20) // PENDING, RESOLVED
  
  ComicId    Int?
  ChapterId  Int?
  
  CreatedAt  DateTime  @default(now())
  ResolvedAt DateTime?

  Comics   Comics?   @relation(fields: [ComicId], references: [Id], onDelete: NoAction, onUpdate: NoAction)
  Chapters Chapters? @relation(fields: [ChapterId], references: [Id], onDelete: NoAction, onUpdate: NoAction)
}